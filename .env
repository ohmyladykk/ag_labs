OPENAI_API_KEY=sk-xxxxxx
LINE_ACCESS_TOKEN=ここに長く複雑な文字列を貼り付ける
git push -u origin main
# 1. HTMLを「Gmailログイン＆決済ボタン」搭載版にアップデート！
$html = @"
<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AG Labs - CEO Dashboard (Secure)</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <div class="container">
        <header>
            <h1>🍎 Antigravity Labs 🐾</h1>
            <p>CEO: Kanoko Sasaki</p>
        </header>

        <main>
            <section class="auth-card">
                <div class="avatar-container">
                    <img src="cyber_panda.png" alt="レッサーパンダCEO" id="panda-avatar" class="panda-avatar">
                </div>
                <h2>🔑 メンバー限定エリア</h2>
                <p>Gmail（Googleアカウント）で安全にログインしてください</p>
                <button class="btn-google">G | Googleでログイン</button>
            </section>

            <section class="payment-card">
                <h3>💎 AG Labs プレミアム</h3>
                <p>リアルタイムAI翻訳 & 実況サポート無制限</p>
                
                <div class="price-box">
                    <span class="currency">¥</span><span class="amount">980</span><span class="period">/月</span>
                </div>

                <div class="payment-options">
                    <button class="btn-stripe">💳 クレジットカードで支払う</button>
                    
                    <button class="btn-nexo">₿ Nexo / 仮想通貨で支払う</button>
                </div>
                <p class="security-note">※パスワードやカード情報はAG Labs側には一切保存されません。Google/Stripe/Nexoの公式システムを経由します。</p>
            </section>
        </main>
    </div>
</body>
</html>
"@; $html | Out-File -FilePath "index.html" -Encoding utf8

# 2. デザインを「高級感のあるダークモード」にアップデート！
$css = @"
body {
    background-color: #0d0d0d;
    color: #e0e0e0;
    font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
    text-align: center;
    margin: 0;
    padding: 0;
}
.container { max-width: 500px; margin: 40px auto; padding: 20px; }
h1 { color: #00f2fe; text-shadow: 0 0 10px rgba(0,242,254,0.5); }

/* カードデザイン */
.auth-card, .payment-card {
    background: #1a1a1a;
    border-radius: 20px;
    padding: 30px;
    margin-bottom: 20px;
    border: 1px solid #333;
    box-shadow: 0 10px 30px rgba(0,0,0,0.5);
}

/* 🐼 パンダの配置 */
.panda-avatar {
    width: 120px; height: 120px;
    border-radius: 50%;
    border: 3px solid #00f2fe;
    margin-bottom: 10px;
}

/* ボタン類 */
button {
    width: 100%; padding: 12px; margin: 10px 0;
    border-radius: 10px; border: none; font-weight: bold; cursor: pointer;
    transition: 0.3s;
}

.btn-google { background: #fff; color: #757575; border: 1px solid #ddd; }
.btn-stripe { background: #635bff; color: white; } /* Stripeカラー */
.btn-nexo { background: #1e4dd8; color: white; } /* Nexoカラー */

button:hover { transform: translateY(-2px); opacity: 0.9; }

/* 料金表示 */
.price-box { margin: 20px 0; font-size: 2em; color: #fff; }
.amount { font-weight: bold; font-size: 1.5em; }
.security-note { font-size: 0.7em; color: #666; margin-top: 15px; }
"@; $css | Out-File -FilePath "style.css" -Encoding utf8

print "✨ ログイン＆決済UIの『骨組み』が完成しました！"
